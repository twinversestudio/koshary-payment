{
  "version": 2,
  "routes": [
    { "src": "/pay", "dest": "/api/pay.js" },
    { "src": "/api/create-order", "dest": "/api/create-order.js" },
    { "src": "/api/check", "dest": "/api/check.js" },
    { "src": "/api/confirm", "dest": "/api/confirm.js" },
